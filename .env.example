# Public Supabase project values. The publishable key is safe for the browser;
# authorization is enforced by Row Level Security.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only values. Never prefix these with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=
GITHUB_TOKEN=
CRON_SECRET=

# Explicit opt-in for non-production demos. Production ignores demo access by default.
ALLOW_DEMO_MODE=false
